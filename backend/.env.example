# App
APP_NAME=GreenField Farm Care API
APP_ENV=development
DEBUG=true

# IMPORTANT: Rotate SECRET_KEY before any non-development deployment.
# Generate a strong key with: python -c "import secrets; print(secrets.token_hex(32))"
# The application will log an ERROR at startup if this default value is used outside development.
SECRET_KEY=your-super-secret-jwt-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/greenfield_db

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS S3
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=greenfield-farmcare

# CORS — comma-separated list of allowed origins.
# Set per environment:
#   Development: ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
#   Staging:     ALLOWED_ORIGINS=https://staging.greenfield.example.com
#   Production:  ALLOWED_ORIGINS=https://app.greenfield.example.com
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

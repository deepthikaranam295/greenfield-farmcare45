# ── App ───────────────────────────────────────────────────────────────────────
APP_NAME=GreenField Farm Care API
APP_ENV=production
DEBUG=false

# Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_STRONG_RANDOM_64_CHAR_HEX

ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Database (set by docker-compose from root .env) ──────────────────────────
# DATABASE_URL is injected by docker-compose; no need to set it here.
# If running outside Docker, uncomment and fill:
# DATABASE_URL=postgresql://greenfield:YOURPASSWORD@localhost:5432/greenfield_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── AWS S3 (for photo uploads) ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=greenfield-farmcare-prod

# ── CORS ──────────────────────────────────────────────────────────────────────
# Production: only your real domain
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

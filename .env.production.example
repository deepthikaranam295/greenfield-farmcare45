# Copy this to .env.production and fill in all values

APP_NAME=GreenField Farm Care API
APP_ENV=production
DEBUG=false

# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_HEX_STRING
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Set by docker-compose from POSTGRES_* env vars — leave as-is
DATABASE_URL=postgresql://greenfield:YOURPASSWORD@db:5432/greenfield_db

# Not used in production (no Redis by default) — leave or remove
REDIS_URL=redis://localhost:6379/0

# AWS S3 (for photo uploads — optional)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-south-1
S3_BUCKET_NAME=greenfield-farmcare

# Must match your actual domain
ALLOWED_ORIGINS=https://YOURDOMAIN.COM,https://www.YOURDOMAIN.COM

# Postgres credentials (used by docker-compose to create the DB)
POSTGRES_PASSWORD=CHANGE_THIS_DB_PASSWORD
POSTGRES_USER=greenfield
POSTGRES_DB=greenfield_db
